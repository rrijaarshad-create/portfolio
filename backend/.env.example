# ✏️ FILL IN YOUR REAL VALUES BEFORE RUNNING

# MongoDB — get this from mongodb.com/atlas (free tier)
MONGODB_URI=mongodb+srv://youruser:yourpassword@cluster0.abc123.mongodb.net/portfolio?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# Email (for contact form notifications) — use Gmail App Password
EMAIL_USER=yourmail@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_TO=yourmail@gmail.com

# CORS — your deployed frontend URL
CLIENT_URL=http://localhost:3000
